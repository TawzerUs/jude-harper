<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="flex-1 px-6 md:px-12 py-12 md:py-16">
  <div class="max-w-3xl mx-auto prose">
    <h1 class="font-serif text-4xl font-bold mb-8">Shipping & Delivery</h1>

    <div class="bg-surface-secondary rounded-bento p-8 mb-8">
      <h2 class="font-serif text-2xl font-bold mb-4">Digital Products (PDF & Audiobook)</h2>
      <div class="flex items-start gap-4 mb-4">
        <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center shrink-0 mt-1">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <div>
          <p class="font-semibold text-lg mb-1">Instant Delivery</p>
          <p class="text-fg-secondary">Digital products are available for download immediately after purchase. No waiting, no shipping.</p>
        </div>
      </div>
      <ul class="text-fg-secondary list-disc pl-6 space-y-1">
        <li>PDF ebooks can be read on any device</li>
        <li>Audiobooks are delivered as MP3 files — stream or download</li>
        <li>Up to 5 downloads per purchase</li>
        <li>Access your downloads anytime via the <a href="/track" class="text-accent font-medium">Track Order</a> page</li>
      </ul>
    </div>

    <div class="bg-surface-secondary rounded-bento p-8 mb-8">
      <h2 class="font-serif text-2xl font-bold mb-4">Physical Books (Paperback)</h2>
      <div class="flex items-start gap-4 mb-4">
        <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center shrink-0 mt-1">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h2a2 2 0 012 2v6a2 2 0 01-2 2H6"/></svg>
        </div>
        <div>
          <p class="font-semibold text-lg mb-1">Print-on-Demand Shipping</p>
          <p class="text-fg-secondary">Physical books are printed on demand by our partner Lulu and shipped directly to you.</p>
        </div>
      </div>

      <h3 class="font-semibold mt-6 mb-3">Estimated Delivery Times</h3>
      <div class="rounded-xl border border-border-subtle overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-white"><tr><th class="text-left px-4 py-2 font-semibold">Region</th><th class="text-left px-4 py-2 font-semibold">Estimated Time</th><th class="text-left px-4 py-2 font-semibold">Shipping</th></tr></thead>
          <tbody class="text-fg-secondary">
            <tr class="border-t border-border-subtle"><td class="px-4 py-2">United States</td><td class="px-4 py-2">5-10 business days</td><td class="px-4 py-2">From $4.95</td></tr>
            <tr class="border-t border-border-subtle"><td class="px-4 py-2">Canada</td><td class="px-4 py-2">7-14 business days</td><td class="px-4 py-2">From $6.95</td></tr>
            <tr class="border-t border-border-subtle"><td class="px-4 py-2">Europe (EU/UK)</td><td class="px-4 py-2">10-20 business days</td><td class="px-4 py-2">From $8.95</td></tr>
            <tr class="border-t border-border-subtle"><td class="px-4 py-2">Rest of World</td><td class="px-4 py-2">14-28 business days</td><td class="px-4 py-2">Varies</td></tr>
          </tbody>
        </table>
      </div>

      <h3 class="font-semibold mt-6 mb-3">Tracking</h3>
      <p class="text-fg-secondary mb-4">Once your book is shipped, you'll receive tracking info. Use our <a href="/track" class="text-accent font-medium">Track Order</a> page to check status anytime.</p>

      <h3 class="font-semibold mt-6 mb-3">Returns</h3>
      <p class="text-fg-secondary">If your book arrives damaged or defective, contact us within 30 days at <strong>hello@judeharper.com</strong> for a replacement or refund.</p>
    </div>

    <div class="bg-surface-secondary rounded-bento p-8">
      <h2 class="font-serif text-2xl font-bold mb-4">Bundles</h2>
      <p class="text-fg-secondary leading-relaxed">When you purchase a bundle that includes both digital and physical products, digital items are delivered instantly while physical items follow the shipping timeline above.</p>
    </div>

    <div class="mt-8 text-center">
      <p class="text-fg-muted text-sm">Questions? Contact us at <strong>hello@judeharper.com</strong></p>
      <p class="text-fg-muted text-sm mt-1">Operated by Tawzer LLC</p>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
