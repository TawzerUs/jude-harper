<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="jh-page">
  <div class="jh-page-head">
    <span class="jh-kicker">§ 01 — SHOP</span>
    <h1>Browse the <em>collection.</em></h1>
    <p>Books, audiobooks, and bundles by Jude Harper.</p>
  </div>

  <div class="jh-tabs">
    <button onclick="filterTab('all')" id="tab-all" class="active">All</button>
    <button onclick="filterTab('books')" id="tab-books">Books</button>
    <button onclick="filterTab('audiobooks')" id="tab-audiobooks">Audiobooks</button>
    <button onclick="filterTab('bundles')" id="tab-bundles">Bundles</button>
  </div>

  <div id="grid-all" class="jh-books-grid">
    <% allProducts.forEach(book => { %>
      <div class="product-item" data-type="<%= book.has_audiobook && !book.has_digital && !book.has_paperback ? 'audiobook' : 'book' %>">
        <%- include('partials/book-card', { book }) %>
      </div>
    <% }) %>
  </div>

  <div id="grid-books" class="hidden jh-books-grid">
    <% books.forEach(book => { %>
      <%- include('partials/book-card', { book }) %>
    <% }) %>
  </div>

  <div id="grid-audiobooks" class="hidden jh-books-grid">
    <% audiobooks.forEach(book => { %>
      <a href="/book/<%= book.slug %>?format=audiobook" class="jh-book-card group">
        <div class="jh-book-cover">
          <% if (book.cover_image) { %>
            <img src="<%= book.cover_image %>" alt="<%= book.title %>">
          <% } else { %>
            <div class="jh-cover-fallback"><span><%= book.title %></span></div>
          <% } %>
        </div>
        <div class="jh-book-info">
          <div class="jh-book-num">AUDIOBOOK</div>
          <h3><%= book.title %></h3>
          <% if (book.description) { %><p><%= book.description %></p><% } %>
          <div class="jh-book-foot">
            <span>$<%= book.audiobook_price ? parseFloat(book.audiobook_price).toFixed(2) : parseFloat(book.price).toFixed(2) %></span>
            <strong>Listen now →</strong>
          </div>
        </div>
      </a>
    <% }) %>
  </div>

  <div id="grid-bundles" class="hidden jh-bundles">
    <% bundles.forEach((bundle, idx) => { %>
      <article class="jh-bundle <%= idx % 2 === 1 ? 'dark' : '' %>">
        <div>
          <div class="jh-bundle-badges">
            <% if (bundle.discount_percent) { %><span>Save <%= bundle.discount_percent %>%</span><% } %>
            <% if (bundle.limited_offer) { %><span>Limited</span><% } %>
          </div>
          <h2><%= bundle.title %></h2>
          <p><%= bundle.description %></p>
          <div class="jh-bundle-price">
            <strong>$<%= parseFloat(bundle.price).toFixed(2) %></strong>
            <% if (bundle.original_price) { %><span>$<%= parseFloat(bundle.original_price).toFixed(2) %></span><% } %>
          </div>
          <button onclick="buyBundle(<%= bundle.id %>)" class="jh-btn-primary">Get Bundle <span>→</span></button>
        </div>
      </article>
    <% }) %>
    <% if (bundles.length === 0) { %><p class="jh-empty">No bundles available yet.</p><% } %>
  </div>

  <% if (allProducts.length === 0) { %>
    <p class="jh-empty">No products available yet. Check back soon.</p>
  <% } %>
</main>

<script>
function filterTab(tab) {
  ['all', 'books', 'audiobooks', 'bundles'].forEach(t => {
    document.getElementById('grid-' + t)?.classList.toggle('hidden', t !== tab);
    const btn = document.getElementById('tab-' + t);
    if (btn) btn.classList.toggle('active', t === tab);
  });
}

async function buyBundle(bundleId) {
  const res = await fetch('/api/checkout-bundle', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ bundleId })
  });
  const data = await res.json();
  if (data.url) window.location.href = data.url;
  else alert(data.error || 'Something went wrong');
}
</script>

<%- include('partials/footer') %>
