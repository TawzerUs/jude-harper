<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="flex-1 py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <h1 class="font-serif text-4xl font-bold mb-8">All Books</h1>
    <% if (books.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% books.forEach(book => { %>
        <%- include('partials/book-card', { book }) %>
      <% }) %>
    </div>
    <% } else { %>
    <p class="text-ink-200 text-lg text-center py-12">No books available yet. Check back soon!</p>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
