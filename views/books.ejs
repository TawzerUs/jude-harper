<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="jh-page">
  <div class="jh-page-head">
    <span class="jh-kicker">§ 01 — CATALOG</span>
    <h1>All <em>books.</em></h1>
    <p>Explore the full collection of books by Jude Harper.</p>
  </div>

  <% if (books.length > 0) { %>
    <div class="jh-books-grid">
      <% books.forEach(book => { %>
        <%- include('partials/book-card', { book }) %>
      <% }) %>
    </div>
  <% } else { %>
    <p class="jh-empty">No books available yet. Check back soon.</p>
  <% } %>
</main>

<%- include('partials/footer') %>
