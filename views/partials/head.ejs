<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            surface: { primary: '#F4EFE6', secondary: '#EBE3D4', inverse: '#1A1714' },
            fg: { primary: '#1A1714', secondary: '#514A42', muted: '#766C60', inverse: '#F4EFE6' },
            accent: '#7A2E1F',
            border: { subtle: '#D6CDBD' }
          },
          fontFamily: {
            serif: ['Instrument Serif', 'Georgia', 'serif'],
            sans: ['Inter Tight', 'system-ui', 'sans-serif'],
            mono: ['JetBrains Mono', 'ui-monospace', 'monospace'],
          },
          borderRadius: {
            'bento': '2px',
            'pill': '2px',
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="jh-body bg-surface-primary text-fg-primary font-sans min-h-screen flex flex-col">
