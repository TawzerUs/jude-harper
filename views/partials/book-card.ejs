<a href="/book/<%= book.slug %>" class="group block bg-surface-secondary rounded-bento overflow-hidden hover:shadow-lg transition-all duration-300">
  <div class="aspect-[3/4] bg-gray-100 overflow-hidden">
    <% if (book.cover_image) { %>
      <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="w-full h-full object-contain bg-surface-secondary group-hover:scale-105 transition-transform duration-500">
    <% } else { %>
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-orange-50 to-orange-100">
        <span class="font-serif text-2xl text-accent/60 text-center px-6"><%= book.title %></span>
      </div>
    <% } %>
  </div>
  <div class="p-6">
    <h3 class="font-serif text-xl font-bold mb-2 group-hover:text-accent transition"><%= book.title %></h3>
    <% if (book.description) { %>
      <p class="text-sm text-fg-secondary mb-4 line-clamp-2 leading-relaxed"><%= book.description %></p>
    <% } %>
    <div class="flex items-center justify-between">
      <p class="text-xl font-bold text-accent">
        <% if (book.price == 0) { %>Free<% } else { %>$<%= parseFloat(book.price).toFixed(2) %><% } %>
      </p>
      <span class="bg-accent text-white text-xs font-semibold px-4 py-2 rounded-pill group-hover:bg-orange-600 transition">Buy Now</span>
    </div>
  </div>
</a>
