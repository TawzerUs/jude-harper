<a href="/book/<%= book.slug %>" class="jh-book-card group">
  <div class="jh-book-cover">
    <% if (book.cover_image) { %>
      <img src="<%= book.cover_image %>" alt="<%= book.title %>">
    <% } else { %>
      <div class="jh-cover-fallback">
        <span><%= book.title %></span>
      </div>
    <% } %>
  </div>
  <div class="jh-book-info">
    <div class="jh-book-num"><%= (book.category || 'New Release').toUpperCase() %></div>
    <h3><%= book.title %></h3>
    <% if (book.description) { %>
      <p><%= book.description %></p>
    <% } %>
    <div class="jh-book-foot">
      <span>
        <%
          const cardPrice = parseFloat(book.price) > 0 ? book.price : book.audiobook_price || book.paperback_price || book.price;
        %>
        <% if (parseFloat(cardPrice) == 0) { %>Free<% } else { %>From $<%= parseFloat(cardPrice).toFixed(2) %><% } %>
      </span>
      <strong>View work →</strong>
    </div>
  </div>
</a>
