<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="flex-1 flex items-center justify-center py-20 px-6">
  <div class="w-full max-w-sm">
    <h1 class="font-serif text-3xl font-bold text-center mb-8">Admin Login</h1>
    <% if (error) { %>
      <p class="text-red-500 text-sm text-center mb-4"><%= error %></p>
    <% } %>
    <form action="/admin/login" method="POST" class="space-y-4">
      <input type="password" name="password" placeholder="Password" required
        class="w-full px-5 py-3.5 border border-border-subtle rounded-xl focus:outline-none focus:border-accent transition">
      <button type="submit" class="w-full bg-accent text-white py-3.5 rounded-pill font-semibold hover:bg-orange-600 transition">Login</button>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
