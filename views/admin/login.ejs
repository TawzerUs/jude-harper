<%- include('../partials/head') %>

<div class="min-h-screen flex items-center justify-center bg-surface-secondary px-6">
  <div class="w-full max-w-sm">
    <div class="bg-white rounded-bento p-8 shadow-sm border border-border-subtle">
      <div class="text-center mb-8">
        <a href="/" class="font-serif text-2xl font-bold text-fg-primary">Jude Harper</a>
        <p class="text-fg-muted text-sm mt-2">Admin Access</p>
      </div>

      <% if (error) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-xl px-4 py-3 mb-6 flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/></svg>
          <%= error %>
        </div>
      <% } %>

      <form action="/admin/login" method="POST" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-fg-muted mb-1.5 uppercase tracking-wider">Email</label>
          <input type="email" name="email" required placeholder="admin@judeharper.com" autocomplete="email"
            class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent transition text-sm">
        </div>
        <div>
          <label class="block text-xs font-semibold text-fg-muted mb-1.5 uppercase tracking-wider">Password</label>
          <input type="password" name="password" required autocomplete="current-password"
            class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent transition text-sm">
        </div>
        <button type="submit" class="w-full bg-accent text-white py-3.5 rounded-pill font-semibold hover:bg-orange-600 transition mt-2">Sign In</button>
      </form>

      <div class="mt-6 pt-4 border-t border-border-subtle text-center">
        <a href="/" class="text-xs text-fg-muted hover:text-fg-primary transition">&larr; Back to store</a>
      </div>
    </div>

    <div class="text-center mt-4">
      <p class="text-xs text-fg-muted">Protected by rate limiting & brute force detection</p>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
