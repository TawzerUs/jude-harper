<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="flex-1 flex items-center justify-center py-20 px-4">
  <div class="w-full max-w-sm">
    <h1 class="font-serif text-3xl font-bold text-center mb-8">Admin Login</h1>
    <% if (error) { %>
      <p class="text-red-600 text-sm text-center mb-4"><%= error %></p>
    <% } %>
    <form action="/admin/login" method="POST" class="space-y-4">
      <input type="password" name="password" placeholder="Password" required
        class="w-full px-4 py-3 border border-brand-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-400">
      <button type="submit" class="w-full bg-ink-900 text-white py-3 rounded-lg font-medium hover:bg-ink-800 transition">Login</button>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
