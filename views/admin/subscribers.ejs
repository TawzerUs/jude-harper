<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="flex-1 py-12 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-8">
      <h1 class="font-serif text-3xl font-bold">Subscribers (<%= subscribers.length %>)</h1>
      <a href="/admin" class="text-brand-500 hover:text-brand-700 text-sm">&larr; Back to Dashboard</a>
    </div>

    <div class="bg-white rounded-xl border border-brand-100 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-brand-50 border-b border-brand-100">
          <tr>
            <th class="text-left px-4 py-3 font-medium">Email</th>
            <th class="text-left px-4 py-3 font-medium">Name</th>
            <th class="text-left px-4 py-3 font-medium">Date</th>
          </tr>
        </thead>
        <tbody>
          <% subscribers.forEach(sub => { %>
          <tr class="border-b border-brand-50">
            <td class="px-4 py-3 font-medium"><%= sub.email %></td>
            <td class="px-4 py-3 text-ink-200"><%= sub.name || '-' %></td>
            <td class="px-4 py-3 text-ink-200"><%= new Date(sub.created_at).toLocaleDateString() %></td>
          </tr>
          <% }) %>
          <% if (subscribers.length === 0) { %>
          <tr><td colspan="3" class="px-4 py-8 text-center text-ink-200">No subscribers yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
