<%- include('../partials/head') %>
<% const page = 'subscribers'; %>
<%- include('partials/admin-nav') %>

<main class="flex-1 px-6 md:px-12 py-8">
  <div class="max-w-7xl mx-auto space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="font-serif text-3xl font-bold">Subscribers</h1>
      <span class="bg-surface-secondary text-fg-secondary text-sm font-medium px-4 py-1.5 rounded-pill"><%= subscribers.length %> total</span>
    </div>

    <div class="rounded-bento border border-border-subtle overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-surface-secondary">
          <tr>
            <th class="text-left px-5 py-3 font-semibold text-fg-muted">Email</th>
            <th class="text-left px-5 py-3 font-semibold text-fg-muted">Name</th>
            <th class="text-left px-5 py-3 font-semibold text-fg-muted">Date</th>
          </tr>
        </thead>
        <tbody>
          <% subscribers.forEach(sub => { %>
          <tr class="border-t border-border-subtle">
            <td class="px-5 py-3.5 font-medium"><%= sub.email %></td>
            <td class="px-5 py-3.5 text-fg-secondary"><%= sub.name || '—' %></td>
            <td class="px-5 py-3.5 text-fg-secondary"><%= new Date(sub.created_at).toLocaleDateString() %></td>
          </tr>
          <% }) %>
          <% if (subscribers.length === 0) { %>
          <tr><td colspan="3" class="px-5 py-10 text-center text-fg-muted">No subscribers yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
