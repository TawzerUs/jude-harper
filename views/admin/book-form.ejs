<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="flex-1 py-12 px-4">
  <div class="max-w-2xl mx-auto">
    <h1 class="font-serif text-3xl font-bold mb-8"><%= book ? 'Edit Book' : 'Add New Book' %></h1>

    <form action="/admin/books" method="POST" enctype="multipart/form-data" class="space-y-6">
      <% if (book) { %>
        <input type="hidden" name="book_id" value="<%= book.id %>">
      <% } %>

      <div>
        <label class="block text-sm font-medium mb-1">Title</label>
        <input type="text" name="title" value="<%= book?.title || '' %>" required
          class="w-full px-4 py-3 border border-brand-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-400">
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Slug (URL-friendly name)</label>
        <input type="text" name="slug" value="<%= book?.slug || '' %>" required placeholder="my-awesome-book"
          class="w-full px-4 py-3 border border-brand-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-400">
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Short Description</label>
        <textarea name="description" rows="2"
          class="w-full px-4 py-3 border border-brand-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-400"><%= book?.description || '' %></textarea>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Long Description</label>
        <textarea name="long_description" rows="5"
          class="w-full px-4 py-3 border border-brand-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-400"><%= book?.long_description || '' %></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-1">Price (USD)</label>
          <input type="number" name="price" step="0.01" min="0" value="<%= book?.price || '0' %>"
            class="w-full px-4 py-3 border border-brand-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-400">
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Category</label>
          <select name="category" class="w-full px-4 py-3 border border-brand-100 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-400">
            <option value="book" <%= book?.category === 'book' ? 'selected' : '' %>>Book</option>
            <option value="ebook" <%= book?.category === 'ebook' ? 'selected' : '' %>>E-Book</option>
            <option value="guide" <%= book?.category === 'guide' ? 'selected' : '' %>>Guide</option>
            <option value="workbook" <%= book?.category === 'workbook' ? 'selected' : '' %>>Workbook</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Cover Image</label>
        <% if (book?.cover_image) { %>
          <p class="text-xs text-ink-200 mb-2">Current: <%= book.cover_image %></p>
        <% } %>
        <input type="file" name="cover" accept="image/*"
          class="w-full text-sm text-ink-200 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-brand-100 file:text-brand-700 file:font-medium hover:file:bg-brand-200">
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Digital File (PDF)</label>
        <% if (book?.file_path) { %>
          <p class="text-xs text-ink-200 mb-2">Current: <%= book.file_path %></p>
        <% } %>
        <input type="file" name="file" accept=".pdf,.epub,.zip"
          class="w-full text-sm text-ink-200 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-brand-100 file:text-brand-700 file:font-medium hover:file:bg-brand-200">
      </div>

      <div class="flex gap-6">
        <label class="flex items-center gap-2">
          <input type="checkbox" name="featured" value="1" <%= book?.featured ? 'checked' : '' %> class="rounded">
          <span class="text-sm">Featured</span>
        </label>
        <label class="flex items-center gap-2">
          <input type="checkbox" name="active" value="1" <%= (book?.active !== 0) ? 'checked' : '' %> class="rounded">
          <span class="text-sm">Active</span>
        </label>
      </div>

      <div class="flex gap-3">
        <button type="submit" class="bg-ink-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-ink-800 transition">
          <%= book ? 'Update Book' : 'Add Book' %>
        </button>
        <a href="/admin" class="border border-brand-200 px-6 py-3 rounded-lg font-medium hover:bg-brand-50 transition">Cancel</a>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
