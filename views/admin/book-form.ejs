<%- include('../partials/head') %>
<% const page = 'dashboard'; %>
<%- include('partials/admin-nav') %>

<main class="flex-1 px-6 md:px-12 py-8">
  <div class="max-w-7xl mx-auto">
    <h1 class="font-serif text-3xl font-bold mb-8"><%= book ? 'Edit Product' : 'Add New Product' %></h1>

    <form action="/admin/books" method="POST" enctype="multipart/form-data">
      <% if (book) { %><input type="hidden" name="book_id" value="<%= book.id %>"><% } %>

      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Left Column -->
        <div class="flex-1 space-y-5">
          <div>
            <label class="block text-sm font-semibold mb-1.5">Title</label>
            <input type="text" name="title" value="<%= book?.title || '' %>" required class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent">
          </div>
          <div>
            <label class="block text-sm font-semibold mb-1.5">Slug</label>
            <input type="text" name="slug" value="<%= book?.slug || '' %>" required placeholder="my-book-title" class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent">
          </div>
          <div>
            <label class="block text-sm font-semibold mb-1.5">Short Description</label>
            <textarea name="description" rows="2" class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent"><%= book?.description || '' %></textarea>
          </div>
          <div>
            <label class="block text-sm font-semibold mb-1.5">Long Description</label>
            <textarea name="long_description" rows="4" class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent"><%= book?.long_description || '' %></textarea>
          </div>

          <!-- Price & Category -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold mb-1.5">Price (USD)</label>
              <input type="number" name="price" step="0.01" min="0" value="<%= book?.price || '0' %>" class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent">
            </div>
            <div>
              <label class="block text-sm font-semibold mb-1.5">Category</label>
              <select name="category" class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent">
                <option value="book" <%= book?.category === 'book' ? 'selected' : '' %>>Book</option>
                <option value="ebook" <%= book?.category === 'ebook' ? 'selected' : '' %>>E-Book</option>
                <option value="audiobook" <%= book?.category === 'audiobook' ? 'selected' : '' %>>Audiobook</option>
                <option value="guide" <%= book?.category === 'guide' ? 'selected' : '' %>>Guide</option>
                <option value="workbook" <%= book?.category === 'workbook' ? 'selected' : '' %>>Workbook</option>
                <option value="course" <%= book?.category === 'course' ? 'selected' : '' %>>Course</option>
                <option value="template" <%= book?.category === 'template' ? 'selected' : '' %>>Template</option>
              </select>
            </div>
          </div>

          <!-- Formats -->
          <div>
            <label class="block text-sm font-semibold mb-2">Available Formats</label>
            <div class="flex gap-6">
              <label class="flex items-center gap-2"><input type="checkbox" name="has_digital" value="1" id="chkDigital" <%= (book?.has_digital !== false) ? 'checked' : '' %> class="accent-accent w-4 h-4" onchange="toggleSections()"> <span class="text-sm">Digital (PDF)</span></label>
              <label class="flex items-center gap-2"><input type="checkbox" name="has_audiobook" value="1" id="chkAudiobook" <%= book?.has_audiobook ? 'checked' : '' %> class="accent-accent w-4 h-4" onchange="toggleSections()"> <span class="text-sm">Audiobook</span></label>
              <label class="flex items-center gap-2"><input type="checkbox" name="has_paperback" value="1" id="chkPaperback" <%= book?.has_paperback ? 'checked' : '' %> class="accent-accent w-4 h-4" onchange="toggleSections()"> <span class="text-sm">Paperback</span></label>
            </div>
          </div>

          <!-- Audiobook Details Section -->
          <div id="audiobookFields" class="<%= book?.has_audiobook ? '' : 'hidden' %> border border-blue-200 bg-blue-50/50 rounded-bento p-5 space-y-4">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/></svg>
              <h3 class="font-bold text-sm">Audiobook Details</h3>
              <% if (book?.audiobook_file) { %>
                <span class="text-xs bg-green-50 text-green-600 px-2 py-0.5 rounded-pill font-semibold">File uploaded</span>
              <% } %>
            </div>
            <p class="text-xs text-fg-secondary">Configure your audiobook — narrator, duration, chapters, and audio files.</p>

            <!-- Pricing & Basics -->
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-xs font-semibold mb-1">Audiobook Price ($)</label>
                <input type="number" name="audiobook_price" step="0.01" min="0" value="<%= book?.audiobook_price || '' %>" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Narrator</label>
                <input type="text" name="audiobook_narrator" value="<%= book?.audiobook_narrator || '' %>" placeholder="Narrator name" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Duration</label>
                <input type="text" name="audiobook_duration" value="<%= book?.audiobook_duration || '' %>" placeholder="2h 30m" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
            </div>

            <!-- Audio Files -->
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold mb-1">Full Audiobook File (MP3)</label>
                <div class="border border-border-subtle rounded-lg px-3 py-2.5 bg-white">
                  <input type="file" name="audiobook_file" accept="audio/*" class="text-xs w-full">
                </div>
                <% if (book?.audiobook_file) { %>
                  <div class="flex items-center gap-2 mt-2 bg-white rounded-lg px-3 py-2 border border-border-subtle">
                    <svg class="w-4 h-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M10 8l6 4-6 4z"/></svg>
                    <span class="text-xs text-fg-secondary truncate"><%= book.audiobook_file %></span>
                    <span class="text-xs text-green-600 font-medium shrink-0">Uploaded</span>
                  </div>
                <% } %>
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Sample Clip (optional, 1-3 min preview)</label>
                <div class="border border-border-subtle rounded-lg px-3 py-2.5 bg-white">
                  <input type="file" name="audiobook_sample" accept="audio/*" class="text-xs w-full">
                </div>
                <% if (book?.audiobook_sample) { %>
                  <div class="flex items-center gap-2 mt-2 bg-white rounded-lg px-3 py-2 border border-border-subtle">
                    <svg class="w-4 h-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M10 8l6 4-6 4z"/></svg>
                    <span class="text-xs text-fg-secondary truncate"><%= book.audiobook_sample %></span>
                  </div>
                <% } %>
              </div>
            </div>

            <!-- Additional Details -->
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-xs font-semibold mb-1">Audio Format</label>
                <select name="audiobook_format" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
                  <option value="MP3" <%= book?.audiobook_format === 'MP3' ? 'selected' : '' %>>MP3</option>
                  <option value="M4A" <%= book?.audiobook_format === 'M4A' ? 'selected' : '' %>>M4A (AAC)</option>
                  <option value="FLAC" <%= book?.audiobook_format === 'FLAC' ? 'selected' : '' %>>FLAC (Lossless)</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Audio Quality</label>
                <select name="audiobook_quality" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
                  <option value="128kbps" <%= book?.audiobook_quality === '128kbps' ? 'selected' : '' %>>128 kbps (Standard)</option>
                  <option value="192kbps" <%= book?.audiobook_quality === '192kbps' ? 'selected' : '' %>>192 kbps (High)</option>
                  <option value="320kbps" <%= book?.audiobook_quality === '320kbps' ? 'selected' : '' %>>320 kbps (Premium)</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Chapters</label>
                <input type="number" name="audiobook_chapters" min="0" value="<%= book?.audiobook_chapters || '' %>" placeholder="12" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
            </div>

            <!-- Chapter List (optional) -->
            <div>
              <label class="block text-xs font-semibold mb-1">Chapter List (one per line: title — duration)</label>
              <textarea name="audiobook_chapter_list" rows="4" placeholder="Chapter 1: The Beginning — 12:30&#10;Chapter 2: Going Deeper — 15:45&#10;Chapter 3: The Turning Point — 18:20" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent"><%= book?.audiobook_chapter_list || '' %></textarea>
            </div>

            <!-- Preview on storefront -->
            <div class="bg-white rounded-lg p-4 border border-border-subtle">
              <p class="text-xs font-semibold text-fg-muted mb-2">Customer experience:</p>
              <div class="flex items-center gap-2 text-xs text-fg-secondary">
                <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded-pill font-semibold">1. Buy</span>
                <span class="text-fg-muted">&rarr;</span>
                <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded-pill font-semibold">2. Stream in browser</span>
                <span class="text-fg-muted">&rarr;</span>
                <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded-pill font-semibold">3. Download MP3</span>
              </div>
            </div>
          </div>

          <div id="paperbackPriceRow" class="<%= book?.has_paperback ? '' : 'hidden' %>">
            <label class="block text-sm font-semibold mb-1.5">Paperback Price (USD)</label>
            <input type="number" name="paperback_price" step="0.01" min="0" value="<%= book?.paperback_price || '' %>" class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent">
          </div>

          <!-- Toggles -->
          <div class="flex gap-6">
            <label class="flex items-center gap-2"><input type="checkbox" name="featured" value="1" <%= book?.featured ? 'checked' : '' %> class="accent-accent w-4 h-4"> <span class="text-sm font-medium">Featured</span></label>
            <label class="flex items-center gap-2"><input type="checkbox" name="active" value="1" <%= (book?.active !== false) ? 'checked' : '' %> class="accent-accent w-4 h-4"> <span class="text-sm font-medium">Active</span></label>
          </div>

          <!-- Product Details (physical/print) -->
          <div id="productDetailsSection" class="<%= book?.has_paperback ? '' : 'hidden' %> border-t border-border-subtle pt-5 space-y-4">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
              <h3 class="font-bold text-sm">Product Details</h3>
            </div>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-xs font-semibold mb-1">Pages</label>
                <input type="number" name="pages" value="<%= book?.pages || '' %>" class="w-full px-3 py-2.5 border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Language</label>
                <input type="text" name="language" value="<%= book?.language || 'English' %>" class="w-full px-3 py-2.5 border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">ISBN-13</label>
                <input type="text" name="isbn" value="<%= book?.isbn || '' %>" class="w-full px-3 py-2.5 border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
            </div>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-xs font-semibold mb-1">Dimensions (in)</label>
                <input type="text" name="dimensions" value="<%= book?.dimensions || '' %>" placeholder="6 x 0.17 x 9" class="w-full px-3 py-2.5 border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Weight (oz)</label>
                <input type="text" name="weight" value="<%= book?.weight || '' %>" class="w-full px-3 py-2.5 border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Publisher</label>
                <input type="text" name="publisher" value="<%= book?.publisher || 'Independently published' %>" class="w-full px-3 py-2.5 border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold mb-1">Publication Date</label>
              <input type="date" name="publication_date" value="<%= book?.publication_date ? new Date(book.publication_date).toISOString().split('T')[0] : '' %>" class="w-full px-3 py-2.5 border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
            </div>
          </div>

          <!-- Lulu Print-on-Demand (paperback only) -->
          <div id="luluSection" class="<%= book?.has_paperback ? '' : 'hidden' %> border border-orange-200 bg-orange-50/50 rounded-bento p-5 space-y-4">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              <h3 class="font-bold text-sm">Lulu Print-on-Demand</h3>
              <span class="text-xs bg-green-50 text-green-600 px-2 py-0.5 rounded-pill font-semibold">Connected</span>
            </div>
            <p class="text-xs text-fg-secondary">When a customer orders a paperback, Lulu automatically prints and ships it. No inventory needed.</p>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold mb-1">Lulu Product ID</label>
                <input type="text" name="lulu_product_id" value="<%= book?.lulu_product_id || '' %>" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Lulu Cover PDF</label>
                <input type="file" name="lulu_cover" accept=".pdf" class="w-full text-sm file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-white file:text-accent file:font-medium">
                <% if (book?.lulu_cover_pdf) { %><p class="text-xs text-fg-muted mt-1">Current: <%= book.lulu_cover_pdf %></p><% } %>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold mb-1">Interior PDF</label>
                <input type="file" name="lulu_interior" accept=".pdf" class="w-full text-sm file:mr-3 file:py-2 file:px-3 file:rounded-lg file:border-0 file:bg-white file:text-accent file:font-medium">
                <% if (book?.lulu_interior_pdf) { %><p class="text-xs text-fg-muted mt-1">Current: <%= book.lulu_interior_pdf %></p><% } %>
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Binding Type</label>
                <select name="lulu_binding" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
                  <% ['Paperback Perfect Bound','Coil Bound','Saddle Stitch','Hardcover Casewrap','Linen Wrap Dust Jacket','Wire-O'].forEach(b => { %>
                    <option value="<%= b %>" <%= book?.lulu_binding === b ? 'selected' : '' %>><%= b %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold mb-1">Paper Type</label>
                <select name="lulu_paper_type" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
                  <% ['60# Cream','60# White','80# White Coated'].forEach(p => { %>
                    <option value="<%= p %>" <%= book?.lulu_paper_type === p ? 'selected' : '' %>><%= p %></option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Trim Size</label>
                <select name="lulu_trim_size" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
                  <% ['4.25 x 6.875','5 x 8','5.5 x 8.5','6 x 9','7 x 10','8.5 x 11'].forEach(s => { %>
                    <option value="<%= s %>" <%= book?.lulu_trim_size === s ? 'selected' : '' %>><%= s %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold mb-1">Interior Color</label>
                <select name="lulu_interior_color" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
                  <% ['Standard Black & White','Premium Black & White','Standard Color','Premium Color'].forEach(c => { %>
                    <option value="<%= c %>" <%= book?.lulu_interior_color === c ? 'selected' : '' %>><%= c %></option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label class="block text-xs font-semibold mb-1">Cover Finish</label>
                <select name="lulu_cover_finish" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
                  <% ['Matte','Glossy'].forEach(f => { %>
                    <option value="<%= f %>" <%= book?.lulu_cover_finish === f ? 'selected' : '' %>><%= f %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div>
              <label class="block text-xs font-semibold mb-1">Print Cost per Copy ($)</label>
              <input type="number" name="lulu_print_cost" step="0.01" value="<%= book?.lulu_print_cost || '' %>" class="w-full px-3 py-2.5 bg-white border border-border-subtle rounded-lg text-sm focus:outline-none focus:border-accent">
            </div>

            <!-- Flow -->
            <div class="flex items-center gap-2 text-xs pt-2">
              <span class="bg-accent text-white px-3 py-1 rounded-pill font-semibold">1. Customer orders</span>
              <span class="text-fg-muted">&rarr;</span>
              <span class="bg-accent text-white px-3 py-1 rounded-pill font-semibold">2. Lulu prints</span>
              <span class="text-fg-muted">&rarr;</span>
              <span class="bg-accent text-white px-3 py-1 rounded-pill font-semibold">3. Ships to customer</span>
            </div>
          </div>
        </div>

        <!-- Right Column -->
        <div class="w-full lg:w-[420px] space-y-6">
          <!-- Cover Upload -->
          <div>
            <label class="block text-sm font-semibold mb-2">Cover Image</label>
            <div class="border-2 border-dashed border-border-subtle rounded-bento p-8 text-center hover:border-accent transition">
              <% if (book?.cover_image) { %>
                <img src="<%= book.cover_image %>" alt="Current cover" class="w-full max-h-60 object-contain mb-3 rounded-lg">
              <% } %>
              <svg class="w-10 h-10 text-fg-muted mx-auto mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              <p class="text-sm text-fg-muted">Drop cover image here</p>
              <p class="text-xs text-gray-400 mt-1">PNG, JPG up to 5MB</p>
              <input type="file" name="cover" accept="image/*" class="mt-3 text-sm">
            </div>
          </div>

          <!-- Gallery -->
          <div>
            <label class="block text-sm font-semibold mb-2">Gallery (Images & Media)</label>
            <% if (typeof gallery !== 'undefined' && gallery.length > 0) { %>
            <div class="grid grid-cols-4 gap-2 mb-3">
              <% gallery.forEach(img => { %>
                <div class="aspect-square rounded-lg overflow-hidden bg-gray-100">
                  <img src="<%= img.url %>" class="w-full h-full object-cover">
                </div>
              <% }) %>
            </div>
            <% } %>
            <div class="border-2 border-dashed border-border-subtle rounded-lg p-4 text-center">
              <input type="file" name="gallery" accept="image/*,video/*" multiple class="text-sm">
              <p class="text-xs text-gray-400 mt-1">Select multiple files for gallery</p>
            </div>
          </div>

          <!-- Digital File -->
          <div id="digitalFileSection" class="<%= (book?.has_digital !== false) ? '' : 'hidden' %>">
            <label class="block text-sm font-semibold mb-2">Digital File (PDF)</label>
            <div class="border border-border-subtle rounded-lg px-4 py-3 flex items-center gap-3">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/></svg>
              <input type="file" name="file" accept=".pdf,.epub,.zip" class="text-sm flex-1">
            </div>
            <% if (book?.file_path) { %><p class="text-xs text-fg-muted mt-1">Current: <%= book.file_path %></p><% } %>
          </div>
        </div>
      </div>

      <!-- Buttons -->
      <div class="flex gap-3 mt-8 pt-6 border-t border-border-subtle">
        <button type="submit" class="bg-accent text-white px-8 py-3 rounded-pill font-semibold hover:bg-orange-600 transition"><%= book ? 'Update Product' : 'Save Product' %></button>
        <a href="/admin" class="border border-border-subtle px-8 py-3 rounded-pill font-medium text-fg-secondary hover:bg-surface-secondary transition">Cancel</a>
      </div>
    </form>
  </div>
</main>

<script>
function toggleSections() {
  const digital = document.getElementById('chkDigital').checked;
  const audio = document.getElementById('chkAudiobook').checked;
  const paper = document.getElementById('chkPaperback').checked;

  document.getElementById('digitalFileSection').classList.toggle('hidden', !digital);
  document.getElementById('audiobookFields').classList.toggle('hidden', !audio);
  document.getElementById('paperbackPriceRow').classList.toggle('hidden', !paper);
  document.getElementById('productDetailsSection').classList.toggle('hidden', !paper);
  document.getElementById('luluSection').classList.toggle('hidden', !paper);
}

// Cover image preview when selected
document.querySelector('[name="cover"]')?.addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(ev) {
    let img = document.getElementById('coverPreview');
    if (!img) {
      img = document.createElement('img');
      img.id = 'coverPreview';
      img.className = 'w-full max-h-60 object-contain mb-3 rounded-lg';
      e.target.parentElement.prepend(img);
    }
    img.src = ev.target.result;
  };
  reader.readAsDataURL(file);
});

// Client-side upload for large files (audiobook, lulu PDFs)
// Files over 4MB go directly to Supabase via signed URL
const form = document.querySelector('form');
form?.addEventListener('submit', async function(e) {
  const largeFields = ['audiobook_file', 'audiobook_sample', 'lulu_cover', 'lulu_interior'];
  const MAX_SERVER_SIZE = 4 * 1024 * 1024; // 4MB

  for (const fieldName of largeFields) {
    const input = form.querySelector(`[name="${fieldName}"]`);
    if (!input?.files?.[0]) continue;
    const file = input.files[0];
    if (file.size <= MAX_SERVER_SIZE) continue;

    // Large file — upload client-side
    e.preventDefault();

    const folder = fieldName.includes('lulu') ? 'lulu' : fieldName.includes('sample') ? 'audiobooks/samples' : 'audiobooks';
    const statusEl = input.parentElement;
    const origHtml = statusEl.innerHTML;
    statusEl.innerHTML = '<p class="text-sm text-accent font-medium">Uploading ' + file.name + '...</p><div class="w-full bg-gray-200 rounded-full h-2 mt-2"><div id="prog_' + fieldName + '" class="bg-accent h-2 rounded-full" style="width:0%"></div></div>';

    try {
      const res = await fetch('/api/upload-url', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ filename: file.name, folder })
      });
      const { signedUrl, token, path, publicUrl } = await res.json();

      await fetch(signedUrl, {
        method: 'PUT',
        headers: { 'Content-Type': file.type },
        body: file
      });

      // Replace file input with hidden input containing the path
      statusEl.innerHTML = '<input type="hidden" name="' + fieldName + '_path" value="' + path + '"><p class="text-xs text-green-600 font-medium">Uploaded: ' + file.name + '</p>';

      // Clear the file input so it's not sent to server
      const dt = new DataTransfer();
      input.files = dt.files;
    } catch (err) {
      statusEl.innerHTML = origHtml;
      alert('Upload failed: ' + err.message);
      return;
    }
  }

  // Now submit the form (small files go through server normally)
  if (!e.defaultPrevented) return;
  form.submit();
});
</script>

