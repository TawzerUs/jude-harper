<%- include('../partials/head') %>

<nav class="bg-surface-inverse text-white">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-4 flex items-center justify-between">
    <span class="font-serif text-xl font-bold">Jude Harper — Admin</span>
    <div class="flex items-center gap-6 text-sm">
      <a href="/admin" class="text-gray-400 hover:text-white transition">Dashboard</a>
      <a href="/admin/orders" class="text-accent font-semibold">Orders</a>
      <a href="/admin/subscribers" class="text-gray-400 hover:text-white transition">Subscribers</a>
    </div>
  </div>
</nav>

<main class="flex-1 px-6 md:px-12 py-8">
  <div class="max-w-7xl mx-auto space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="font-serif text-3xl font-bold">Orders</h1>
      <span class="bg-surface-secondary text-fg-secondary text-sm font-medium px-4 py-1.5 rounded-pill"><%= orders.length %> total</span>
    </div>

    <div class="rounded-bento border border-border-subtle overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-surface-secondary">
          <tr>
            <th class="text-left px-5 py-3 font-semibold text-fg-muted">Date</th>
            <th class="text-left px-5 py-3 font-semibold text-fg-muted">Book</th>
            <th class="text-left px-5 py-3 font-semibold text-fg-muted">Email</th>
            <th class="text-left px-5 py-3 font-semibold text-fg-muted">Format</th>
            <th class="text-left px-5 py-3 font-semibold text-fg-muted">Amount</th>
            <th class="text-left px-5 py-3 font-semibold text-fg-muted">Status</th>
            <th class="text-left px-5 py-3 font-semibold text-fg-muted">Downloads</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(order => { %>
          <tr class="border-t border-border-subtle">
            <td class="px-5 py-3.5 text-fg-secondary"><%= new Date(order.created_at).toLocaleDateString() %></td>
            <td class="px-5 py-3.5 font-medium"><%= order.book_title %></td>
            <td class="px-5 py-3.5 text-fg-secondary"><%= order.email %></td>
            <td class="px-5 py-3.5">
              <span class="text-xs px-2 py-0.5 rounded-pill font-medium <%= (order.format === 'paperback') ? 'bg-purple-50 text-purple-600' : 'bg-blue-50 text-blue-600' %>">
                <%= order.format || 'digital' %>
              </span>
            </td>
            <td class="px-5 py-3.5 font-semibold">$<%= parseFloat(order.amount).toFixed(2) %></td>
            <td class="px-5 py-3.5">
              <span class="px-3 py-1 rounded-pill text-xs font-semibold <%= order.status === 'completed' ? 'bg-green-50 text-green-600' : 'bg-yellow-50 text-yellow-600' %>">
                <%= order.status %>
              </span>
              <% if (order.lulu_print_job_id) { %>
                <span class="text-xs text-fg-muted ml-1">Lulu: <%= order.lulu_print_job_id %></span>
              <% } %>
            </td>
            <td class="px-5 py-3.5 text-fg-secondary"><%= order.download_count %></td>
          </tr>
          <% }) %>
          <% if (orders.length === 0) { %>
          <tr><td colspan="7" class="px-5 py-10 text-center text-fg-muted">No orders yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
