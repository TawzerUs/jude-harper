<%- include('../partials/head') %>
<% const page = 'bundles'; %>
<%- include('partials/admin-nav') %>

<main class="flex-1 px-6 md:px-12 py-8">
  <div class="max-w-3xl mx-auto">
    <h1 class="font-serif text-3xl font-bold mb-8"><%= bundle ? 'Edit Bundle' : 'Create Bundle' %></h1>

    <form action="/admin/bundles" method="POST" enctype="multipart/form-data" class="space-y-6">
      <% if (bundle) { %><input type="hidden" name="bundle_id" value="<%= bundle.id %>"><% } %>

      <div>
        <label class="block text-sm font-semibold mb-1.5">Bundle Title</label>
        <input type="text" name="title" value="<%= bundle?.title || '' %>" required class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent">
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1.5">Slug</label>
        <input type="text" name="slug" value="<%= bundle?.slug || '' %>" required placeholder="complete-collection" class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent">
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1.5">Description</label>
        <textarea name="description" rows="3" class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent"><%= bundle?.description || '' %></textarea>
      </div>

      <div class="grid grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-semibold mb-1.5">Bundle Price ($)</label>
          <input type="number" name="price" step="0.01" min="0" value="<%= bundle?.price || '' %>" required class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent">
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1.5">Original Price ($)</label>
          <input type="number" name="original_price" step="0.01" min="0" value="<%= bundle?.original_price || '' %>" class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent">
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1.5">Discount %</label>
          <input type="number" name="discount_percent" min="0" max="100" value="<%= bundle?.discount_percent || '' %>" class="w-full px-4 py-3 border border-border-subtle rounded-xl focus:outline-none focus:border-accent">
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold mb-1.5">Cover Image</label>
        <input type="file" name="cover" accept="image/*" class="text-sm">
        <% if (bundle?.cover_image) { %><p class="text-xs text-fg-muted mt-1">Current: has cover</p><% } %>
      </div>

      <div class="flex gap-6">
        <label class="flex items-center gap-2"><input type="checkbox" name="active" value="1" <%= (!bundle || bundle.active) ? 'checked' : '' %> class="accent-accent w-4 h-4"> <span class="text-sm font-medium">Active</span></label>
        <label class="flex items-center gap-2"><input type="checkbox" name="limited_offer" value="1" <%= bundle?.limited_offer ? 'checked' : '' %> class="accent-accent w-4 h-4"> <span class="text-sm font-medium">Limited Offer</span></label>
      </div>

      <!-- Bundle Items -->
      <div class="border-t border-border-subtle pt-6">
        <h3 class="font-bold text-lg mb-4">Bundle Items</h3>
        <p class="text-sm text-fg-secondary mb-4">Select which books and formats to include in this bundle.</p>

        <div class="space-y-3" id="bundleItems">
          <% if (books && books.length > 0) { %>
            <% books.forEach(book => { %>
            <div class="bg-surface-secondary rounded-xl p-4">
              <p class="font-medium mb-2"><%= book.title %></p>
              <div class="flex gap-4">
                <% const isIncluded = (fmt) => bundle?.items?.some(i => i.book_id === book.id && i.format === fmt); %>
                <label class="flex items-center gap-2">
                  <input type="checkbox" name="items[]" value="<%= book.id %>:digital" <%= isIncluded('digital') ? 'checked' : '' %> class="accent-accent w-4 h-4">
                  <span class="text-sm">Digital (PDF)</span>
                </label>
                <% if (book.has_audiobook) { %>
                <label class="flex items-center gap-2">
                  <input type="checkbox" name="items[]" value="<%= book.id %>:audiobook" <%= isIncluded('audiobook') ? 'checked' : '' %> class="accent-accent w-4 h-4">
                  <span class="text-sm">Audiobook</span>
                </label>
                <% } %>
                <% if (book.has_paperback) { %>
                <label class="flex items-center gap-2">
                  <input type="checkbox" name="items[]" value="<%= book.id %>:paperback" <%= isIncluded('paperback') ? 'checked' : '' %> class="accent-accent w-4 h-4">
                  <span class="text-sm">Paperback</span>
                </label>
                <% } %>
              </div>
            </div>
            <% }) %>
          <% } else { %>
            <p class="text-fg-muted">No books available. Add books first.</p>
          <% } %>
        </div>
      </div>

      <div class="flex gap-3 pt-4">
        <button type="submit" class="bg-accent text-white px-8 py-3 rounded-pill font-semibold hover:bg-orange-600 transition"><%= bundle ? 'Update Bundle' : 'Create Bundle' %></button>
        <a href="/admin/bundles" class="border border-border-subtle px-8 py-3 rounded-pill font-medium text-fg-secondary hover:bg-surface-secondary transition">Cancel</a>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
