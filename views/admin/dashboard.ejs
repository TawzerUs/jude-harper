<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="flex-1 py-12 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-8">
      <h1 class="font-serif text-3xl font-bold">Dashboard</h1>
      <div class="flex gap-3">
        <a href="/admin/books/new" class="bg-brand-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-brand-600 transition">+ Add Book</a>
        <a href="/admin/orders" class="border border-brand-200 px-4 py-2 rounded-lg text-sm font-medium hover:bg-brand-50 transition">Orders</a>
        <a href="/admin/subscribers" class="border border-brand-200 px-4 py-2 rounded-lg text-sm font-medium hover:bg-brand-50 transition">Subscribers</a>
        <a href="/admin/logout" class="text-ink-200 px-4 py-2 text-sm hover:text-red-500 transition">Logout</a>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      <div class="bg-white p-6 rounded-xl border border-brand-100">
        <p class="text-sm text-ink-200">Total Revenue</p>
        <p class="text-3xl font-bold text-brand-600">$<%= revenue.toFixed(2) %></p>
      </div>
      <div class="bg-white p-6 rounded-xl border border-brand-100">
        <p class="text-sm text-ink-200">Orders</p>
        <p class="text-3xl font-bold"><%= orderCount %></p>
      </div>
      <div class="bg-white p-6 rounded-xl border border-brand-100">
        <p class="text-sm text-ink-200">Subscribers</p>
        <p class="text-3xl font-bold"><%= subscriberCount %></p>
      </div>
    </div>

    <!-- Books Table -->
    <h2 class="font-serif text-2xl font-bold mb-4">Books</h2>
    <div class="bg-white rounded-xl border border-brand-100 overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-brand-50 border-b border-brand-100">
          <tr>
            <th class="text-left px-4 py-3 font-medium">Title</th>
            <th class="text-left px-4 py-3 font-medium">Price</th>
            <th class="text-left px-4 py-3 font-medium">Status</th>
            <th class="text-left px-4 py-3 font-medium">Featured</th>
            <th class="text-right px-4 py-3 font-medium">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% books.forEach(book => { %>
          <tr class="border-b border-brand-50 hover:bg-brand-50/50">
            <td class="px-4 py-3 font-medium"><%= book.title %></td>
            <td class="px-4 py-3"><% if (book.price === 0) { %>Free<% } else { %>$<%= book.price.toFixed(2) %><% } %></td>
            <td class="px-4 py-3">
              <span class="px-2 py-1 rounded text-xs font-medium <%= book.active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
                <%= book.active ? 'Active' : 'Draft' %>
              </span>
            </td>
            <td class="px-4 py-3"><%= book.featured ? 'Yes' : '-' %></td>
            <td class="px-4 py-3 text-right">
              <a href="/admin/books/<%= book.id %>/edit" class="text-brand-500 hover:text-brand-700 mr-3">Edit</a>
              <form action="/admin/books/<%= book.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Delete this book?')">
                <button class="text-red-400 hover:text-red-600">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
          <% if (books.length === 0) { %>
          <tr><td colspan="5" class="px-4 py-8 text-center text-ink-200">No books yet. Add your first book!</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
