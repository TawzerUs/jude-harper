<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="flex-1">
  <!-- Hero -->
  <section class="px-4 md:px-12 py-10 md:py-24">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-8 md:gap-16">
      <div class="flex-1 space-y-5 md:space-y-6 text-center md:text-left">
        <span class="inline-block bg-surface-secondary text-accent text-xs md:text-sm font-semibold px-3 md:px-4 py-1.5 md:py-2 rounded-pill">New Release — Available Now</span>
        <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-fg-primary leading-[1.15]">The book that changes how you see yourself</h1>
        <p class="text-base md:text-lg text-fg-secondary leading-relaxed max-w-lg mx-auto md:mx-0">Jude Harper writes the words you needed to hear — raw, honest, and transformative. For anyone who's been silently carrying too much.</p>
        <div class="flex flex-col sm:flex-row items-center gap-3 md:gap-4 pt-2">
          <a href="/books" class="w-full sm:w-auto bg-accent text-white px-8 py-3.5 rounded-pill font-semibold hover:bg-orange-600 transition text-center">Get Your Copy</a>
          <a href="/about" class="w-full sm:w-auto border-2 border-accent text-accent px-8 py-3.5 rounded-pill font-semibold hover:bg-accent hover:text-white transition text-center">Learn More</a>
        </div>
      </div>
      <div class="w-full max-w-sm md:max-w-none md:w-[480px] shrink-0">
        <%
          const heroProduct = [...featured, ...books].find(b => b.cover_image);
        %>
        <% if (heroProduct?.cover_image) { %>
          <img src="<%= heroProduct.cover_image %>" alt="<%= heroProduct.title %>" class="w-full aspect-[3/4] object-contain rounded-bento shadow-xl bg-surface-secondary">
        <% } else { %>
          <div class="w-full aspect-[3/4] bg-gradient-to-br from-orange-50 to-orange-100 rounded-bento flex flex-col items-center justify-center gap-4">
            <svg class="w-20 h-20 text-accent/30" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/></svg>
            <span class="font-serif text-3xl text-accent/50">Jude Harper</span>
          </div>
        <% } %>
      </div>
    </div>
  </section>

  <!-- Featured Books -->
  <% if (books.length > 0) { %>
  <section class="px-6 md:px-12 py-16">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-10">
        <h2 class="font-serif text-3xl md:text-4xl font-bold">Featured Books</h2>
        <a href="/books" class="text-accent font-semibold text-sm hover:text-orange-700 transition">View All &rarr;</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% books.forEach(book => { %>
          <%- include('partials/book-card', { book }) %>
        <% }) %>
      </div>
    </div>
  </section>
  <% } else { %>
  <section class="px-6 md:px-12 py-16 text-center">
    <p class="text-fg-secondary text-lg">Books coming soon. Subscribe to get notified!</p>
  </section>
  <% } %>

  <!-- Newsletter -->
  <section class="bg-surface-inverse text-white px-6 md:px-12 py-20">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="font-serif text-3xl md:text-4xl font-bold mb-4">Stay in the loop</h2>
      <p class="text-gray-400 mb-8">Get notified about new releases, exclusive content, and early access.</p>
      <% if (typeof req !== 'undefined' && req.query?.subscribed) { %>
        <p class="text-accent font-semibold">Thanks for subscribing!</p>
      <% } else { %>
      <form action="/subscribe" method="POST" class="flex gap-3 max-w-md mx-auto">
        <input type="email" name="email" required placeholder="your@email.com" class="flex-1 px-5 py-3.5 rounded-pill bg-white/5 border border-gray-700 text-white placeholder-gray-500 focus:outline-none focus:border-accent">
        <button type="submit" class="bg-accent text-white px-7 py-3.5 rounded-pill font-semibold hover:bg-orange-600 transition">Subscribe</button>
      </form>
      <% } %>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
