<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="jh-main">
  <%
    const catalog = books || [];
    const heroProduct = [...(featured || []), ...catalog].find(b => b.cover_image) || catalog[0];
  %>

  <section class="jh-hero">
    <div class="jh-hero-left">
      <div class="jh-hero-meta">
        <span class="jh-kicker">Vol. 02 · 2026</span>
        <span class="jh-kicker">No. 014 — New Release</span>
      </div>
      <div>
        <h1>The book<br>that <em>changes</em><br>how you see<br>yourself.</h1>
        <p>Jude Harper writes the words you needed to hear — <strong>raw, honest, transformative.</strong> For anyone who's been silently carrying too much.</p>
        <div class="jh-hero-actions">
          <a href="/shop" class="jh-btn-primary">Get Your Copy <span>→</span></a>
          <a href="<%= heroProduct?.slug ? `/book/${heroProduct.slug}` : '/books' %>" class="jh-btn-ghost">Read an excerpt</a>
        </div>
      </div>
      <div class="jh-hero-foot">
        <span>EST. 2024 · TAWZER LLC</span>
        <span>SCROLL ↓ TO READ</span>
      </div>
    </div>

    <div class="jh-hero-right">
      <div class="jh-hero-book-wrap">
        <% if (heroProduct?.cover_image) { %>
          <img src="<%= heroProduct.cover_image %>" alt="<%= heroProduct.title %>" class="jh-hero-book">
        <% } else { %>
          <div class="jh-hero-book jh-hero-book-fallback">Jude Harper</div>
        <% } %>
      </div>
      <div class="jh-hero-quote">For anyone who's been silently carrying too much.</div>
    </div>
  </section>

  <div class="jh-marquee" aria-hidden="true">
    <div>
      <span>Words that stay with you</span>
      <span>Read in the quiet hours</span>
      <span>For the silently exhausted</span>
      <span>Honest. Raw. Transformative.</span>
      <span>Words that stay with you</span>
      <span>Read in the quiet hours</span>
      <span>For the silently exhausted</span>
      <span>Honest. Raw. Transformative.</span>
    </div>
  </div>

  <section class="jh-featured">
    <div class="jh-section-head">
      <span>§ 01 — CATALOG</span>
      <h2>Featured <em>works.</em></h2>
      <a href="/shop">View all →</a>
    </div>

    <% if (catalog.length > 0) { %>
      <div class="jh-books-grid">
        <% catalog.slice(0, 6).forEach(book => { %>
          <%- include('partials/book-card', { book }) %>
        <% }) %>
      </div>
    <% } else { %>
      <p class="jh-empty">Books coming soon. Subscribe to get notified.</p>
    <% } %>
  </section>

  <section class="jh-quote-band">
    <div>"</div>
    <p>You weren't too much.<br>You were just the only one paying attention.</p>
    <cite>— From Jude Harper</cite>
  </section>

  <section class="jh-audio">
    <div>
      <span class="jh-kicker">§ 02 — LISTEN</span>
      <h3>Hear it<br>in the<br><em>quiet</em> hours.</h3>
      <p>Audio companions designed for the moments between — the commute, the late shower, the 3 a.m. doubt. Press play and breathe out.</p>
      <a href="/audiobooks" class="jh-btn-ghost">Browse audiobooks →</a>
    </div>
    <div class="jh-player">
      <div class="jh-player-row">
        <button aria-label="Play preview">▶</button>
        <div>
          <strong>Belief Rewiring</strong>
          <span>CHAPTER 02 · 5-MINUTE MINDSHIFT</span>
        </div>
      </div>
      <div class="jh-waveform" aria-hidden="true">
        <% for (let i = 0; i < 60; i++) { %>
          <span style="height:<%= 28 + Math.round(Math.abs(Math.sin(i * 0.42)) * 54) %>%;<%= i < 19 ? 'background:#7A2E1F;opacity:.95' : '' %>"></span>
        <% } %>
      </div>
      <div class="jh-progress"><span></span></div>
      <div class="jh-player-times"><span>01:42</span><span>-03:18</span></div>
    </div>
  </section>

  <section class="jh-news">
    <div>
      <span class="jh-kicker">§ 03 — STAY CLOSE</span>
      <h3>Letters,<br>occasionally,<br>when there's<br>something <em>worth</em> saying.</h3>
    </div>
    <div class="jh-news-form">
      <p>New releases, exclusive essays, and early access — sent only when there's a reason. No noise.</p>
      <% if (typeof subscribed !== 'undefined' && subscribed) { %>
        <p class="jh-subscribe-ok">Thanks for subscribing.</p>
      <% } else { %>
        <form action="/subscribe" method="POST">
          <input type="email" name="email" required placeholder="your@email.address">
          <button type="submit">Subscribe <span>→</span></button>
        </form>
      <% } %>
      <p class="jh-news-fine">NO SPAM · UNSUBSCRIBE WITH ONE CLICK · WE WILL NEVER SHARE YOUR EMAIL</p>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
