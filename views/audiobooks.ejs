<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="flex-1">
  <!-- Hero -->
  <section class="px-6 md:px-12 py-16 md:py-20 bg-gradient-to-b from-surface-secondary to-surface-primary">
    <div class="max-w-4xl mx-auto text-center space-y-6">
      <div class="w-20 h-20 bg-accent/10 rounded-full flex items-center justify-center mx-auto">
        <svg class="w-10 h-10 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/></svg>
      </div>
      <h1 class="font-serif text-4xl md:text-5xl font-bold">Audiobooks</h1>
      <p class="text-fg-secondary text-lg max-w-2xl mx-auto">Listen anywhere, anytime. Our audiobooks are professionally narrated and available as instant MP3 downloads. Perfect for your commute, workout, or quiet evening.</p>
    </div>
  </section>

  <!-- Audiobook Grid -->
  <section class="px-6 md:px-12 py-12">
    <div class="max-w-7xl mx-auto">
      <% if (books.length > 0) { %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <% books.forEach(book => { %>
        <div class="bg-surface-secondary rounded-bento overflow-hidden flex">
          <!-- Cover -->
          <div class="w-48 shrink-0">
            <% if (book.cover_image) { %>
              <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="w-full h-full object-contain bg-surface-secondary">
            <% } else { %>
              <div class="w-full h-full bg-gradient-to-br from-orange-50 to-orange-100 flex items-center justify-center">
                <svg class="w-12 h-12 text-accent/40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/></svg>
              </div>
            <% } %>
          </div>
          <!-- Info -->
          <div class="flex-1 p-6 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-2 mb-2">
                <span class="bg-blue-50 text-blue-600 text-xs font-semibold px-3 py-1 rounded-pill">Audiobook</span>
                <% if (book.has_digital !== false) { %>
                  <span class="bg-green-50 text-green-600 text-xs font-semibold px-3 py-1 rounded-pill">Also in PDF</span>
                <% } %>
              </div>
              <h3 class="font-serif text-xl font-bold mb-2"><%= book.title %></h3>
              <p class="text-sm text-fg-secondary leading-relaxed mb-4 line-clamp-2"><%= book.description %></p>
            </div>
            <div class="flex items-center justify-between">
              <div>
                <span class="text-2xl font-bold text-accent">$<%= book.audiobook_price ? parseFloat(book.audiobook_price).toFixed(2) : parseFloat(book.price).toFixed(2) %></span>
                <span class="text-xs text-fg-muted ml-2">MP3 Download</span>
              </div>
              <a href="/book/<%= book.slug %>" class="bg-accent text-white text-sm px-5 py-2.5 rounded-pill font-semibold hover:bg-orange-600 transition">Listen Now</a>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <p class="text-center text-fg-muted py-16 text-lg">No audiobooks available yet. Check back soon!</p>
      <% } %>
    </div>
  </section>

  <!-- Features -->
  <section class="px-6 md:px-12 py-16 bg-surface-secondary">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-center mb-12">Why Audiobooks?</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center space-y-3">
          <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 class="font-semibold text-lg">Instant Access</h3>
          <p class="text-sm text-fg-secondary">Download immediately after purchase. No waiting, no shipping.</p>
        </div>
        <div class="text-center space-y-3">
          <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
          </div>
          <h3 class="font-semibold text-lg">Any Device</h3>
          <p class="text-sm text-fg-secondary">MP3 format works on phones, tablets, laptops — everywhere.</p>
        </div>
        <div class="text-center space-y-3">
          <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M10 8l6 4-6 4z"/></svg>
          </div>
          <h3 class="font-semibold text-lg">Listen Anywhere</h3>
          <p class="text-sm text-fg-secondary">Commuting, working out, or relaxing — take your books with you.</p>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
