<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="flex-1">
  <section class="px-6 md:px-12 py-12 md:py-16 text-center">
    <h1 class="font-serif text-4xl md:text-5xl font-bold mb-3">Bundles & Offers</h1>
    <p class="text-fg-secondary text-lg">Save more when you buy together. Limited-time offers and curated collections.</p>
  </section>

  <section class="px-6 md:px-12 pb-16">
    <div class="max-w-5xl mx-auto space-y-8">
      <% if (bundles.length > 0) { %>
        <% bundles.forEach((bundle, idx) => { %>
        <div class="rounded-bento <%= idx % 2 === 1 ? 'bg-surface-inverse text-white' : 'bg-surface-secondary' %> flex flex-col md:flex-row overflow-hidden">
          <!-- Info -->
          <div class="flex-1 p-8 md:p-10 space-y-5">
            <div class="flex gap-2">
              <% if (bundle.discount_percent) { %>
                <span class="text-xs font-bold px-3 py-1 rounded-pill <%= idx % 2 === 1 ? 'bg-orange-500/20 text-accent' : 'bg-yellow-100 text-yellow-700' %>">Save <%= bundle.discount_percent %>%</span>
              <% } %>
              <% if (bundle.limited_offer) { %>
                <span class="text-xs font-bold px-3 py-1 rounded-pill bg-orange-500/20 text-accent">Limited Offer</span>
              <% } %>
            </div>
            <h2 class="font-serif text-2xl md:text-3xl font-bold"><%= bundle.title %></h2>
            <p class="text-sm leading-relaxed <%= idx % 2 === 1 ? 'text-gray-400' : 'text-fg-secondary' %>"><%= bundle.description %></p>

            <!-- Items -->
            <div class="space-y-2">
              <% if (bundle.items) { bundle.items.forEach(item => { %>
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <% if (item.format === 'audiobook') { %><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/>
                  <% } else { %><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/>
                  <% } %>
                </svg>
                <span class="text-sm <%= idx % 2 === 1 ? 'text-gray-300' : 'text-fg-primary' %>"><%= item.book_title %> <span class="text-xs <%= idx % 2 === 1 ? 'text-gray-500' : 'text-fg-muted' %>">(<%= item.format %>)</span></span>
              </div>
              <% }) } %>
            </div>

            <!-- Pricing -->
            <div class="flex items-center gap-3">
              <span class="text-3xl font-bold">$<%= parseFloat(bundle.price).toFixed(2) %></span>
              <% if (bundle.original_price) { %>
                <span class="text-base line-through <%= idx % 2 === 1 ? 'text-gray-500' : 'text-fg-muted' %>">$<%= parseFloat(bundle.original_price).toFixed(2) %></span>
              <% } %>
            </div>

            <button onclick="buyBundle(<%= bundle.id %>)" class="bg-accent text-white px-8 py-3 rounded-pill font-semibold hover:bg-orange-600 transition">Get This Bundle</button>
          </div>

          <!-- Cover thumbnails -->
          <% if (bundle.items && bundle.items.length > 0) { %>
          <div class="w-full md:w-80 flex md:flex-col gap-2 p-4 items-center justify-center">
            <% bundle.items.slice(0, 3).forEach(item => { %>
              <% if (item.cover_image) { %>
              <div class="w-24 md:w-28 aspect-[3/4] rounded-xl overflow-hidden bg-gray-200 shrink-0">
                <img src="<%= item.cover_image %>" alt="" class="w-full h-full object-cover">
              </div>
              <% } %>
            <% }) %>
          </div>
          <% } %>
        </div>
        <% }) %>
      <% } else { %>
        <p class="text-center text-fg-muted py-16 text-lg">No bundles available right now. Check back soon!</p>
      <% } %>
    </div>
  </section>
</main>

<script>
async function buyBundle(bundleId) {
  const res = await fetch('/api/checkout-bundle', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ bundleId })
  });
  const data = await res.json();
  if (data.url) window.location.href = data.url;
  else alert(data.error || 'Something went wrong');
}
</script>

<%- include('partials/footer') %>
