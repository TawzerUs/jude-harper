<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="flex-1 py-16 px-4">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Cover -->
      <div class="aspect-[3/4] bg-brand-100 rounded-xl overflow-hidden">
        <% if (book.cover_image) { %>
          <img src="<%= book.cover_image %>" alt="<%= book.title %>" class="w-full h-full object-cover">
        <% } else { %>
          <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-brand-200 to-brand-300">
            <span class="font-serif text-3xl text-white/80 text-center px-6"><%= book.title %></span>
          </div>
        <% } %>
      </div>

      <!-- Details -->
      <div class="flex flex-col justify-center">
        <span class="text-sm text-brand-500 font-medium uppercase tracking-wider mb-2"><%= book.category %></span>
        <h1 class="font-serif text-4xl font-bold mb-4"><%= book.title %></h1>
        <p class="text-ink-200 mb-6"><%= book.description %></p>

        <% if (book.long_description) { %>
          <div class="prose prose-sm text-ink-200 mb-8">
            <%= book.long_description %>
          </div>
        <% } %>

        <div class="flex items-center gap-6 mb-8">
          <span class="text-3xl font-bold text-brand-600">
            <% if (book.price === 0) { %>Free<% } else { %>$<%= book.price.toFixed(2) %><% } %>
          </span>
          <span class="text-sm text-ink-200">Digital download (PDF)</span>
        </div>

        <% if (book.price > 0) { %>
          <button onclick="buyBook(<%= book.id %>)" class="bg-ink-900 text-white px-8 py-4 rounded-lg font-medium text-lg hover:bg-ink-800 transition w-full md:w-auto text-center">
            Buy Now
          </button>
        <% } else { %>
          <a href="/api/download/free-<%= book.slug %>" class="bg-ink-900 text-white px-8 py-4 rounded-lg font-medium text-lg hover:bg-ink-800 transition w-full md:w-auto text-center inline-block">
            Download Free
          </a>
        <% } %>
      </div>
    </div>
  </div>
</main>

<script>
async function buyBook(bookId) {
  const res = await fetch('/api/checkout', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ bookId })
  });
  const data = await res.json();
  if (data.url) window.location.href = data.url;
  else alert(data.error || 'Something went wrong');
}
</script>

<%- include('partials/footer') %>
