<%- include('partials/head') %>
<%- include('partials/nav') %>

<main class="jh-detail">
  <%
    const qFmt = typeof reqFormat !== 'undefined' ? reqFormat : null;
    const autoFmt = book.has_digital !== false ? 'digital' : book.has_audiobook ? 'audiobook' : 'paperback';
    const defaultFmt = (qFmt === 'audiobook' && book.has_audiobook) ? 'audiobook' : (qFmt === 'paperback' && book.has_paperback) ? 'paperback' : (qFmt === 'digital' && book.has_digital !== false) ? 'digital' : autoFmt;
    const initPrice = defaultFmt === 'audiobook' && book.audiobook_price ? parseFloat(book.audiobook_price) : defaultFmt === 'paperback' && book.paperback_price ? parseFloat(book.paperback_price) : parseFloat(book.price);
    const initLabel = defaultFmt === 'audiobook' ? 'Audiobook (MP3)' : defaultFmt === 'paperback' ? 'Paperback — Ships in 5-10 days' : 'Digital Download (PDF)';
    const publicationLabel = book.publication_date ? new Date(book.publication_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) : 'Available now';
  %>

  <section class="jh-detail-hero">
    <div class="jh-detail-cover-wrap">
      <% if (book.cover_image) { %>
        <img id="mainImage" src="<%= book.cover_image %>" alt="<%= book.title %>" class="jh-detail-cover">
      <% } else { %>
        <div class="jh-detail-cover jh-detail-cover-fallback"><%= book.title %></div>
      <% } %>

      <% if (typeof gallery !== 'undefined' && gallery.length > 0) { %>
        <div class="jh-gallery">
          <% if (book.cover_image) { %>
            <button class="active" onclick="setMainImage('<%= book.cover_image %>', this)"><img src="<%= book.cover_image %>" alt=""></button>
          <% } %>
          <% gallery.forEach((img) => { %>
            <% if (img.type !== 'video') { %>
              <button onclick="setMainImage('<%= img.url %>', this)"><img src="<%= img.url %>" alt=""></button>
            <% } %>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="jh-detail-info">
      <span class="jh-kicker">Books / <%= book.category || 'Jude Harper' %></span>
      <h1><%= book.title %></h1>
      <% if (book.description) { %><p class="jh-detail-sub"><%= book.description %></p><% } %>

      <div class="jh-detail-meta">
        <div><span class="jh-kicker">Format</span><strong id="formatLabel"><%= initLabel %></strong></div>
        <div><span class="jh-kicker">Published</span><strong><%= publicationLabel %></strong></div>
        <% if (book.pages) { %><div><span class="jh-kicker">Length</span><strong><%= book.pages %> pages</strong></div><% } %>
        <% if (book.language) { %><div><span class="jh-kicker">Language</span><strong><%= book.language %></strong></div><% } %>
      </div>

      <% if (book.long_description) { %>
        <div class="jh-detail-desc"><%= book.long_description %></div>
      <% } %>

      <% if (book.has_digital || book.has_paperback || book.has_audiobook) { %>
        <div class="jh-format-picker">
          <span class="jh-kicker">Choose format</span>
          <div>
            <% if (book.has_digital !== false) { %>
              <button id="btnDigital" onclick="selectFormat('digital')" class="<%= defaultFmt === 'digital' ? 'active' : '' %>"><span>Digital</span><strong>$<%= parseFloat(book.price).toFixed(2) %></strong></button>
            <% } %>
            <% if (book.has_audiobook) { %>
              <button id="btnAudiobook" onclick="selectFormat('audiobook')" class="<%= defaultFmt === 'audiobook' ? 'active' : '' %>"><span>Audiobook</span><strong>$<%= book.audiobook_price ? parseFloat(book.audiobook_price).toFixed(2) : parseFloat(book.price).toFixed(2) %></strong></button>
            <% } %>
            <% if (book.has_paperback) { %>
              <button id="btnPaperback" onclick="selectFormat('paperback')" class="<%= defaultFmt === 'paperback' ? 'active' : '' %>"><span>Paperback</span><strong>$<%= book.paperback_price ? parseFloat(book.paperback_price).toFixed(2) : parseFloat(book.price).toFixed(2) %></strong></button>
            <% } %>
          </div>
        </div>
      <% } %>

      <div class="jh-format-notes">
        <div id="digitalInfo" class="<%= defaultFmt === 'digital' ? '' : 'hidden' %>">Instant download after purchase — read on any device.</div>
        <div id="audiobookInfo" class="<%= defaultFmt === 'audiobook' ? '' : 'hidden' %>">
          <p>Stream in browser and download <%= book.audiobook_format || 'MP3' %> to keep.</p>
          <% if (book.audiobook_sample) { %>
            <audio controls preload="none">
              <source src="<%= typeof sampleUrl !== 'undefined' ? sampleUrl : '#' %>" type="audio/mpeg">
            </audio>
          <% } %>
        </div>
        <div id="paperbackInfo" class="<%= defaultFmt === 'paperback' ? '' : 'hidden' %>">Printed and shipped — estimated 5-10 business days.</div>
      </div>

      <div class="jh-detail-buy">
        <span id="priceDisplay">$<%= initPrice.toFixed(2) %></span>
        <button onclick="buyBook(<%= book.id %>)" class="jh-btn-primary">Add to cart — $<span id="ctaPrice"><%= initPrice.toFixed(2) %></span> <span>→</span></button>
      </div>

      <div class="jh-detail-fine">
        <span>✦ Secure checkout powered by Stripe</span>
        <span>✦ Instant digital delivery</span>
        <% if (book.has_paperback) { %><span>✦ Paperback ships worldwide</span><% } %>
      </div>
    </div>
  </section>

  <section class="jh-detail-pull">
    <p>You weren't <em>too much.</em> You were just the only one paying attention.</p>
    <cite>— JUDE HARPER</cite>
  </section>

  <section class="jh-detail-content">
    <aside>
      <span class="jh-kicker">Product Details</span>
      <dl>
        <% if (book.publisher) { %><dt>Publisher</dt><dd><%= book.publisher %></dd><% } %>
        <% if (book.publication_date) { %><dt>Publication date</dt><dd><%= new Date(book.publication_date).toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'}) %></dd><% } %>
        <% if (book.isbn) { %><dt>ISBN-13</dt><dd><%= book.isbn %></dd><% } %>
        <% if (book.dimensions) { %><dt>Dimensions</dt><dd><%= book.dimensions %></dd><% } %>
        <% if (book.weight) { %><dt>Weight</dt><dd><%= book.weight %> oz</dd><% } %>
      </dl>
    </aside>
    <div>
      <span class="jh-kicker">An Excerpt — Chapter One</span>
      <h2>The Silent Carrying</h2>
      <p class="lede">Most of us do not fall apart in public. We fall apart in the car, in the shower, in the three minutes before we walk into a room and become someone bearable again.</p>
      <p>This is a book for that version of you. The one nobody else knows is tired. The one who has been holding everything together for so long you have forgotten what it would feel like to set it down.</p>
      <p>If you have been silently carrying too much: I see you. Keep reading. We will go deeper together.</p>
    </div>
  </section>
</main>

<script>
function setMainImage(url, thumb) {
  const img = document.getElementById('mainImage');
  if (img) img.src = url;
  document.querySelectorAll('.jh-gallery button').forEach(t => t.classList.remove('active'));
  if (thumb) thumb.classList.add('active');
}

let selectedFormat = '<%= defaultFmt %>';
const prices = {
  digital: <%= parseFloat(book.price).toFixed(2) %>,
  audiobook: <%= book.audiobook_price ? parseFloat(book.audiobook_price).toFixed(2) : parseFloat(book.price).toFixed(2) %>,
  paperback: <%= book.paperback_price ? parseFloat(book.paperback_price).toFixed(2) : parseFloat(book.price).toFixed(2) %>
};
const labels = { digital: 'Digital Download (PDF)', audiobook: 'Audiobook (MP3)', paperback: 'Paperback — Ships in 5-10 days' };

function selectFormat(fmt) {
  selectedFormat = fmt;
  ['Digital', 'Audiobook', 'Paperback'].forEach(f => {
    const btn = document.getElementById('btn' + f);
    if (btn) btn.classList.toggle('active', fmt === f.toLowerCase());
  });
  const infoMap = { digital: 'digitalInfo', audiobook: 'audiobookInfo', paperback: 'paperbackInfo' };
  Object.values(infoMap).forEach(id => document.getElementById(id)?.classList.add('hidden'));
  document.getElementById(infoMap[fmt])?.classList.remove('hidden');
  const price = prices[fmt];
  document.getElementById('priceDisplay').textContent = '$' + price.toFixed(2);
  document.getElementById('ctaPrice').textContent = price.toFixed(2);
  document.getElementById('formatLabel').textContent = labels[fmt];
}

async function buyBook(bookId) {
  const res = await fetch('/api/checkout', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ bookId, format: selectedFormat })
  });
  const data = await res.json();
  if (data.url) window.location.href = data.url;
  else alert(data.error || 'Something went wrong');
}
</script>

<%- include('partials/footer') %>
